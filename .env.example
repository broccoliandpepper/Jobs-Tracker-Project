# ============================================
# JobTracker — Configuration complète Phase 2
# Copier ce fichier en .env et adapter les valeurs
# ============================================

# Phase 1 — Configuration de base
PORT=3333
DB_PATH=./jobs.db
NODE_ENV=development
LOG_LEVEL=info

# Phase 2 — Backup DB
# Nombre de backups à conserver dans ./db-backup/ (0 = infini)
BACKUP_RETENTION=10

# Phase 2 — Ollama IA
# Mettre ENABLE_AI=true et démarrer Ollama (ollama serve) pour activer
ENABLE_AI=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AI_TIMEOUT=15000

# Phase 2 — n8n Webhooks
# Mettre ENABLE_WEBHOOK=true pour activer la réception depuis n8n
ENABLE_WEBHOOK=false
N8N_MODE=local          # local | docker-mac | docker-linux | docker-custom
N8N_CUSTOM_IP=          # Requis uniquement si N8N_MODE=docker-custom
WEBHOOK_SECRET=         # Optionnel — laisser vide = pas d'authentification
